# EX1
# Calcule o total de alunos em duas turmas:
# uma com 28 alunos e outra com 32.

total_alunos = 28 + 32

print("Total de alunos:", total_alunos)
print("Tipo:", type(total_alunos))


# EX2
# Um pacote de dados tem 500MB.
# Após baixar 150MB, quanto resta?

restante = 500 - 150

print("Restam:", restante, "MB")
print("Tipo:", type(restante))


# EX3
# Uma caixa contém 24 ovos.
# Quantos ovos existem em 8 caixas?

ovos = 24 * 8

print("Quantidade de ovos:", ovos)
print("Tipo:", type(ovos))


# EX4
# Divida 10 litros de suco igualmente
# entre 3 pessoas e mostre o resultado.

suco = 10 / 3

print("Cada pessoa recebe:", suco)
print("Tipo:", type(suco))


# EX5
# Use divisão inteira para descobrir
# quantas pessoas recebem 3 litros inteiros
# dos 10 litros disponíveis.

pessoas = 10 // 3

print("Pessoas que recebem 3 litros:", pessoas)
print("Tipo:", type(pessoas))


# EX6
# Calcule o resto da divisão de 10 por 3.

resto = 10 % 3

print("Resto da divisão:", resto)
print("Tipo:", type(resto))


# EX7
# Calcule 2 elevado à potência 8.

potencia = 2 ** 8

print("Resultado:", potencia)
print("Tipo:", type(potencia))


# EX8
# Calcule a raiz quadrada de 81
# usando exponenciação.

raiz = 81 ** 0.5

print("Raiz quadrada:", raiz)
print("Tipo:", type(raiz))


# EX9
# Calcule a expressão:
# (10 + 5) * 2 - 8 / 4

expressao = (10 + 5) * 2 - 8 / 4

print("Resultado da expressão:", expressao)
print("Tipo:", type(expressao))


# EX10
# Mostre o resultado da divisão de -7 por 2
# usando divisão inteira e o operador de resto.

divisao_inteira = -7 // 2
resto_divisao = -7 % 2

print("Divisão inteira:", divisao_inteira)
print("Resto:", resto_divisao)
print("Tipo da divisão inteira:", type(divisao_inteira))
print("Tipo do resto:", type(resto_divisao))
